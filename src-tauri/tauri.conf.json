{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/1.x/tooling/cli/schema.json",
  "build": {
    "beforeBuildCommand": "node ../build.js",
    "beforeDevCommand": "node ../build.js",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Close-up Systems",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.closeupsystems.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Close-up Systems",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  }
}
